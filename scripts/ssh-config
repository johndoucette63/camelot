# Camelot Infrastructure SSH Config
# Append to ~/.ssh/config or include via: Include ~/Code/camelot/scripts/ssh-config

Host holygrail
    HostName 192.168.10.129
    User john
    IdentityFile ~/.ssh/id_ed25519

Host torrentbox
    HostName 192.168.10.141
    User john
    IdentityFile ~/.ssh/id_ed25519

Host nas
    HostName 192.168.10.105
    User pi
    IdentityFile ~/.ssh/id_ed25519

Host mediaserver
    HostName 192.168.10.150
    User pi
    IdentityFile ~/.ssh/id_ed25519

# Shared defaults for all managed hosts
Host holygrail torrentbox nas mediaserver
    StrictHostKeyChecking accept-new
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10
