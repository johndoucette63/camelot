# Frigate NVR stack — secrets template.
#
# Copy to `.env` on HOLYGRAIL before first deploy. `.env` is gitignored.
# Regenerate the Mosquitto passwords file after editing (see mosquitto/config/passwords.example).

# ── Pinned image tags ────────────────────────────────────────────────────
# Pin to specific SHAs or semver tags at deploy time per FR-001.
FRIGATE_IMAGE_TAG=stable-tensorrt
MOSQUITTO_IMAGE_TAG=2

# ── Camera credentials ───────────────────────────────────────────────────
# Reolink Video Doorbell WiFi. Use only Reolink-safe characters:
#   a-z A-Z 0-9 @$*~_-+=!?.,:;'()[]
# Other characters silently break RTSP encoding (FR-009).
FRIGATE_DOORBELL_USER=admin
FRIGATE_DOORBELL_PASSWORD=

# Wansview garage camera (RTSP path: /live/ch0). Plain ASCII password,
# no URL encoding needed. See specs/019-garage-camera/.
FRIGATE_GARAGE_USER=admin
FRIGATE_GARAGE_PASSWORD=

# ── MQTT credentials ─────────────────────────────────────────────────────
# frigate = internal broker user (Frigate → Mosquitto on 1883)
# homeassistant = LAN broker user (HA → Mosquitto on 1884)
FRIGATE_MQTT_USER=frigate
FRIGATE_MQTT_PASSWORD=
HA_MQTT_USER=homeassistant
HA_MQTT_PASSWORD=

# ── PHASE 2 (deferred) ───────────────────────────────────────────────────
# Uncomment when onboarding cameras behind the Reolink Home Hub.
# FRIGATE_HUB_USER=admin
# FRIGATE_HUB_PASSWORD=
