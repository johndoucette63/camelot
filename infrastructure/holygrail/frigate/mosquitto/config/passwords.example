# Mosquitto passwords seed — instructions, NOT a committed passwords file.
#
# The real `passwords` file is generated on HOLYGRAIL after first deploy
# and is gitignored. Do NOT commit it.
#
# Generate from the real .env values (ssh holygrail; cd /opt/frigate-stack):
#
#   set -a; . ./.env; set +a
#   touch ./mosquitto/config/passwords
#   docker run --rm \
#     -v "$(pwd)/mosquitto/config/passwords:/mosquitto/config/passwords" \
#     eclipse-mosquitto:${MOSQUITTO_IMAGE_TAG:-2} \
#     mosquitto_passwd -b /mosquitto/config/passwords \
#     "$FRIGATE_MQTT_USER" "$FRIGATE_MQTT_PASSWORD"
#   docker run --rm \
#     -v "$(pwd)/mosquitto/config/passwords:/mosquitto/config/passwords" \
#     eclipse-mosquitto:${MOSQUITTO_IMAGE_TAG:-2} \
#     mosquitto_passwd -b /mosquitto/config/passwords \
#     "$HA_MQTT_USER" "$HA_MQTT_PASSWORD"
#   chmod 0600 ./mosquitto/config/passwords
#   docker compose restart mosquitto
#
# Verify:
#
#   mosquitto_sub -h holygrail -p 1884 \
#     -u "$HA_MQTT_USER" -P "$HA_MQTT_PASSWORD" \
#     -t 'frigate/#' -v
