# Vaultwarden — secrets template.
#
# Copy to `.env` on HOLYGRAIL before first deploy. `.env` is gitignored.
#
#   cp .env.example .env

# ── Image pin ────────────────────────────────────────────────────────────
# Override to upgrade. Check https://github.com/dani-garcia/vaultwarden/releases
VAULTWARDEN_IMAGE_TAG=1.32.7

# ── Public URL ───────────────────────────────────────────────────────────
# Must match the URL clients hit (Traefik routes Host(`vault.holygrail`)).
# Required for WebAuthn / 2FA registration to bind to the right origin.
# Web vault + browser extensions require https (Web Crypto secure context).
DOMAIN=https://vault.holygrail

# ── Admin panel ──────────────────────────────────────────────────────────
# Generate an Argon2 hash and paste it here:
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# Hash format: $argon2id$v=19$m=...   (escape every `$` as `$$` for compose)
# Admin panel URL: http://vault.holygrail/admin
ADMIN_TOKEN=

# ── Account creation ─────────────────────────────────────────────────────
# Leave true while you register your own user. Flip to false afterwards (or
# manage further accounts via the admin-panel invite flow).
SIGNUPS_ALLOWED=true
# No SMTP configured, so signup verification must stay off (would block reg).
SIGNUPS_VERIFY=false
# Allow inviting users from the admin panel.
INVITATIONS_ALLOWED=true

# ── Misc ─────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
TZ=America/Denver
