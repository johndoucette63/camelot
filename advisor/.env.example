# PostgreSQL
POSTGRES_DB=advisor
POSTGRES_USER=john
POSTGRES_PASSWORD=changeme

# Backend (bridge-networked containers use service DNS name)
DATABASE_URL=postgresql+asyncpg://john:changeme@postgres:5432/advisor

# Scanner (host-networked sidecar uses 127.0.0.1 because postgres exposes port to host)
# Note: docker-compose.yml sets DATABASE_URL for the scanner service automatically;
#       you only need to override this if running the scanner outside Docker.
# DATABASE_URL=postgresql+asyncpg://john:changeme@127.0.0.1:5432/advisor

# LAN scan settings
SCAN_INTERVAL_SECONDS=900    # seconds between scans (default: 15 minutes)
SCAN_TARGET=192.168.10.0/24  # CIDR subnet to scan

# External services
OLLAMA_URL=http://ollama.holygrail

# General
TZ=America/Denver

# Home Assistant integration (feature 016)
# Generate a Fernet key once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The advisor will refuse to start if ADVISOR_ENCRYPTION_KEY is unset or malformed.
# Rotating the key requires re-saving the HA connection in Settings -> Home Assistant
# (the old ciphertext is unreadable with a new key).
ADVISOR_ENCRYPTION_KEY=
HA_POLL_INTERVAL_SECONDS=60
HA_REQUEST_TIMEOUT_SECONDS=10
HA_NOTIFY_RETRY_BUDGET_SECONDS=300
